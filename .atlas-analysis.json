  "keyFeatures": [
    "Batch auction settlement with Balancer Vault integration",
    "EIP-712 order signing with multiple signature schemes",
    "Solver authentication and authorization system",
    "TypeScript SDK for order creation and interaction",
    "Multi-chain deployment support (Ethereum, Gnosis Chain, Arbitrum, Optimism, BSC, Polygon, Base, Avalanche)",
    "Flexible order types (fill-or-kill, partial fill, buy/sell orders)",
    "Pre/intra/post settlement interactions for AMM integration",
    "Gas-optimized smart contracts with extensive testing"
  ],
  "publicApiSurface": [
    "GPv2Settlement.settle()",
    "GPv2Settlement.invalidateOrder()",
    "GPv2Settlement.setPreSignature()",
    "GPv2Settlement.domainSeparator()",
    "GPv2AllowListAuthentication.isSolver()",
    "GPv2AllowListAuthentication.addSolver()",
    "GPv2AllowListAuthentication.removeSolver()",
    "GPv2VaultRelayer.transferFromAccounts()",
    "domain() - EIP-712 domain creation",
    "Order interface - Order creation and validation",
    "signOrder() - Order signing utilities",
    "encodeSettlement() - Settlement encoding",
    "encodeInteraction() - Interaction encoding",
    "computeOrderUid() - Order UID computation",
    "hashTypedData() - EIP-712 hashing"
  ]
